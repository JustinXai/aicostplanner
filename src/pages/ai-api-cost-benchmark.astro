<script>
  // =========================================================
  //  Calculator logic
  // =========================================================

  function get(id) { return document.getElementById(id); }
  function num(id) { return parseFloat(get(id).value) || 0; }
  function fmt(n, decimals) {
    if (isNaN(n) || !isFinite(n)) return '—';
    return n.toLocaleString('en-US', { minimumFractionDigits: decimals, maximumFractionDigits: decimals });
  }
  function fmtUSD(n) {
    if (isNaN(n) || !isFinite(n)) return '—';
    return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }

  // ----- LLM -----
  function calcLLM() {
    var users = num('llm-users');
    var days = num('llm-days');
    var rpu = num('llm-rpu');
    var itok = num('llm-itok');
    var otok = num('llm-otok');
    var ipr = num('llm-ipr');
    var opr = num('llm-opr');
    var retry = num('llm-retry') / 100;
    var buf = num('llm-buf') / 100;

    var monthlyReqs = users * days * rpu;
    var inputCost = monthlyReqs * itok / 1e6 * ipr;
    var outputCost = monthlyReqs * otok / 1e6 * opr;
    var baseCost = inputCost + outputCost;
    var afterRetry = baseCost * (1 + retry);
    var planned = afterRetry * (1 + buf);

    var el = get('llm-result');
    el.innerHTML = '<div class="result-grid"><div class="result-item"><span class="result-label">Monthly requests</span><span class="result-value">' + fmt(monthlyReqs, 0) + '</span></div><div class="result-item"><span class="result-label">Input cost</span><span class="result-value">' + fmtUSD(inputCost) + '</span></div><div class="result-item"><span class="result-label">Output cost</span><span class="result-value">' + fmtUSD(outputCost) + '</span></div><div class="result-item"><span class="result-label">Base API cost</span><span class="result-value">' + fmtUSD(baseCost) + '</span></div><div class="result-item"><span class="result-label">After retries (' + fmt(retry*100,0) + '%)</span><span class="result-value">' + fmtUSD(afterRetry) + '</span></div><div class="result-item result-item--highlight"><span class="result-label">Planned monthly budget</span><span class="result-value">' + fmtUSD(planned) + '</span></div></div>';
  }

  // ----- Agent -----
  function calcAgent() {
    var tasks = num('agent-tasks');
    var calls = num('agent-calls');
    var itok = num('agent-itok');
    var otok = num('agent-otok');
    var ttok = num('agent-ttok');
    var retry = num('agent-retry') / 100;
    var ipr = num('agent-ipr');
    var opr = num('agent-opr');
    var crdp = num('agent-crdp') / 100;
    var crwtp = num('agent-crwtp') / 100;
    var buf = num('agent-buf') / 100;

    var monthlyCalls = tasks * calls;
    var cacheDiscount = crdp * (1 - crwtp);
    var effectiveInputRate = ipr * (1 - cacheDiscount);
    var costPerCall = (itok + ttok) / 1e6 * effectiveInputRate + otok / 1e6 * opr;
    var baseCost = monthlyCalls * costPerCall;
    var afterRetry = baseCost * (1 + retry);
    var planned = afterRetry * (1 + buf);

    var el = get('agent-result');
    el.innerHTML = '<div class="result-grid"><div class="result-item"><span class="result-label">Monthly model calls</span><span class="result-value">' + fmt(monthlyCalls, 0) + '</span></div><div class="result-item"><span class="result-label">Base call cost</span><span class="result-value">' + fmtUSD(costPerCall) + '</span></div><div class="result-item"><span class="result-label">Monthly base cost</span><span class="result-value">' + fmtUSD(baseCost) + '</span></div><div class="result-item"><span class="result-label">After retries (' + fmt(retry*100,0) + '%)</span><span class="result-value">' + fmtUSD(afterRetry) + '</span></div><div class="result-item"><span class="result-label">Cost per completed task</span><span class="result-value">' + fmtUSD(planned / tasks) + '</span></div><div class="result-item result-item--highlight"><span class="result-label">Planned monthly budget</span><span class="result-value">' + fmtUSD(planned) + '</span></div></div>';
  }

  // ----- Image -----
  function calcImage() {
    var accepted = num('img-permonth');
    var attempts = num('img-attempts');
    var price = num('img-price');
    var fail = num('img-fail') / 100;
    var buf = num('img-buf') / 100;

    var submitted = accepted * attempts;
    var genCost = submitted * price;
    var effectiveCost = genCost / accepted;
    var planned = genCost * (1 + buf);

    var el = get('image-result');
    el.innerHTML = '<div class="result-grid"><div class="result-item"><span class="result-label">Submitted jobs</span><span class="result-value">' + fmt(submitted, 0) + '</span></div><div class="result-item"><span class="result-label">Listed generation cost</span><span class="result-value">' + fmtUSD(genCost) + '</span></div><div class="result-item"><span class="result-label">Effective cost per accepted image</span><span class="result-value">' + fmtUSD(effectiveCost) + '</span></div><div class="result-item"><span class="result-label">After buffer (' + fmt(buf*100,0) + '%)</span><span class="result-value">' + fmtUSD(planned) + '</span></div><div class="result-item result-item--highlight"><span class="result-label">Planned monthly budget</span><span class="result-value">' + fmtUSD(planned) + '</span></div></div>';
  }

  // ----- Video -----
  function calcVideo() {
    var accepted = num('vid-videos');
    var attempts = num('vid-attempts');
    var secs = num('vid-seconds');
    var mode = get('vid-mode').value;
    var pps = num('vid-pps');
    var ppj = num('vid-ppj');
    var fail = num('vid-fail') / 100;
    var buf = num('vid-buf') / 100;

    var submitted = accepted * attempts;
    var totalSecs = submitted * secs;
    var baseSpend = (mode === 'per-second') ? totalSecs * pps : submitted * ppj;
    var planned = baseSpend * (1 + buf);

    var el = get('video-result');
    el.innerHTML = '<div class="result-grid"><div class="result-item"><span class="result-label">Submitted jobs</span><span class="result-value">' + fmt(submitted, 0) + '</span></div><div class="result-item"><span class="result-label">Total generated seconds</span><span class="result-value">' + fmt(totalSecs, 0) + 's</span></div><div class="result-item"><span class="result-label">Base spend (' + mode + ')</span><span class="result-value">' + fmtUSD(baseSpend) + '</span></div><div class="result-item"><span class="result-label">Effective cost per accepted video</span><span class="result-value">' + fmtUSD(planned / accepted) + '</span></div><div class="result-item result-item--highlight"><span class="result-label">Planned monthly budget</span><span class="result-value">' + fmtUSD(planned) + '</span></div></div>';
  }

  // ----- Attach listeners -----
  ['llm-users','llm-days','llm-rpu','llm-itok','llm-otok','llm-ipr','llm-opr','llm-retry','llm-buf'].forEach(function(id) {
    var el = get(id);
    if (el) el.addEventListener('input', calcLLM);
  });
  ['agent-tasks','agent-calls','agent-itok','agent-otok','agent-ttok','agent-retry','agent-ipr','agent-opr','agent-crdp','agent-crwtp','agent-buf'].forEach(function(id) {
    var el = get(id);
    if (el) el.addEventListener('input', calcAgent);
  });
  ['img-permonth','img-attempts','img-price','img-fail','img-buf'].forEach(function(id) {
    var el = get(id);
    if (el) el.addEventListener('input', calcImage);
  });
  ['vid-videos','vid-attempts','vid-seconds','vid-mode','vid-pps','vid-ppj','vid-fail','vid-buf'].forEach(function(id) {
    var el = get(id);
    if (el) el.addEventListener('input', calcVideo);
  });

  // ----- Tabs -----
  document.querySelectorAll('.calc-tab').forEach(function(tab) {
    tab.addEventListener('click', function() {
      document.querySelectorAll('.calc-tab').forEach(function(t) {
        t.classList.remove('active');
        t.setAttribute('aria-selected', 'false');
      });
      document.querySelectorAll('.calc-panel').forEach(function(p) {
        p.classList.remove('active');
        p.setAttribute('hidden', '');
      });
      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');
      var panelId = 'calc-' + tab.dataset.tab;
      var panel = get(panelId);
      if (panel) {
        panel.classList.add('active');
        panel.removeAttribute('hidden');
      }
    });
  });

  // ----- Presets -----
  var PRESETS = {
    'prototype': {
      'llm-users':'100','llm-days':'20','llm-rpu':'3','llm-itok':'2000','llm-otok':'500','llm-ipr':'3.00','llm-opr':'15.00','llm-retry':'3','llm-buf':'15',
      'agent-tasks':'500','agent-calls':'8','agent-itok':'20000','agent-otok':'3000','agent-ttok':'5000','agent-retry':'8','agent-ipr':'3.00','agent-opr':'15.00','agent-crdp':'30','agent-crwtp':'90','agent-buf':'20',
      'img-permonth':'1000','img-attempts':'1.5','img-price':'0.04','img-fail':'10','img-buf':'15',
      'vid-videos':'100','vid-attempts':'1.3','vid-seconds':'8','vid-mode':'per-second','vid-pps':'0.10','vid-ppj':'0.80','vid-fail':'20','vid-buf':'20',
    },
    'small-production': {
      'llm-users':'2000','llm-days':'25','llm-rpu':'4','llm-itok':'3000','llm-otok':'800','llm-ipr':'3.00','llm-opr':'15.00','llm-retry':'5','llm-buf':'20',
      'agent-tasks':'2000','agent-calls':'10','agent-itok':'25000','agent-otok':'4000','agent-ttok':'8000','agent-retry':'8','agent-ipr':'3.00','agent-opr':'15.00','agent-crdp':'25','agent-crwtp':'90','agent-buf':'25',
      'img-permonth':'5000','img-attempts':'1.5','img-price':'0.04','img-fail':'10','img-buf':'20',
      'vid-videos':'500','vid-attempts':'1.3','vid-seconds':'10','vid-mode':'per-second','vid-pps':'0.10','vid-ppj':'1.00','vid-fail':'20','vid-buf':'25',
    },
    'agent-heavy': {
      'llm-users':'50','llm-days':'20','llm-rpu':'10','llm-itok':'5000','llm-otok':'2000','llm-ipr':'3.00','llm-opr':'15.00','llm-retry':'10','llm-buf':'25',
      'agent-tasks':'500','agent-calls':'8','agent-itok':'20000','agent-otok':'3000','agent-ttok':'5000','agent-retry':'8','agent-ipr':'3.00','agent-opr':'15.00','agent-crdp':'30','agent-crwtp':'90','agent-buf':'20',
      'img-permonth':'2000','img-attempts':'2.0','img-price':'0.04','img-fail':'15','img-buf':'20',
      'vid-videos':'200','vid-attempts':'1.5','vid-seconds':'12','vid-mode':'per-second','vid-pps':'0.10','vid-ppj':'1.20','vid-fail':'25','vid-buf':'30',
    },
  };

  document.querySelectorAll('.preset-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var preset = btn.dataset.preset;
      if (preset === 'reset') {
        // reset handled by clearing — just reload
        document.querySelectorAll('input[id^="llm-"], input[id^="agent-"], input[id^="img-"], input[id^="vid-"]').forEach(function(inp) {
          inp.value = inp.defaultValue;
        });
        calcLLM(); calcAgent(); calcImage(); calcVideo();
        return;
      }
      var vals = PRESETS[preset];
      if (!vals) return;
      Object.keys(vals).forEach(function(id) {
        var el = get(id);
        if (el) el.value = vals[id];
      });
      calcLLM(); calcAgent(); calcImage(); calcVideo();
    });
  });

  // ----- Copy -----
  get('calc-copy').addEventListener('click', function() {
    var active = document.querySelector('.calc-panel.active');
    if (!active) return;
    var result = active.querySelector('.calc-result');
    if (!result) return;
    var text = result.textContent || '';
    navigator.clipboard.writeText(text).catch(function(){});
    var btn = get('calc-copy');
    var orig = btn.textContent;
    btn.textContent = 'Copied!';
    setTimeout(function() { btn.textContent = orig; }, 2000);
  });

  // ----- Export -----
  get('calc-export').addEventListener('click', function() {
    var lines = ['calculator,month,value'];
    var panels = [
      { id: 'calc-llm', label: 'LLM' },
      { id: 'calc-agent', label: 'Agent' },
      { id: 'calc-image', label: 'Image' },
      { id: 'calc-video', label: 'Video' },
    ];
    var now = new Date().toISOString().slice(0, 7);
    panels.forEach(function(p) {
      var el = get(p.id);
      if (!el || !el.classList.contains('active')) return;
      var vals = el.querySelectorAll('input[id], select[id]');
      vals.forEach(function(inp) {
        var label = inp.labels && inp.labels[0] ? inp.labels[0].textContent : inp.id;
        lines.push(p.label + ',' + now + ',' + (inp.value || ''));
      });
    });
    var csv = lines.join('\n');
    var blob = new Blob([csv], { type: 'text/csv' });
    var url = URL.createObjectURL(blob);
    var a = document.createElement('a');
    a.href = url;
    a.download = 'ai-api-cost-estimate-' + now + '.csv';
    a.click();
    URL.revokeObjectURL(url);
  });

  // Init
  calcLLM();
</script>

