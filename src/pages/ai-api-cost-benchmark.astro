---
import PageLayout from '../layouts/PageLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import '../styles/global.css';

const siteUrl = 'https://aicostplanner.com';
const currentDate = new Date().toISOString().split('T')[0];
const route = '/ai-api-cost-benchmark/';
const lastReviewed = 'June 17, 2026';

const breadcrumbs = [{ label: 'AI API Cost Benchmark', href: route }];
const internalLinks = [
  { href: '/claude-code-token-cost/', label: 'Claude Code Token Cost' },
  { href: '/openrouter-credits/', label: 'OpenRouter Credits' },
  { href: '/image-generation-api-cost/', label: 'Image Generation API Cost' },
  { href: '/gpt-image-api-cost/', label: 'GPT Image API Cost' },
  { href: '/video-generation-api-cost/', label: 'Video Generation API Cost' },
  { href: '/failed-generation-cost/', label: 'Failed Generation Cost' },
  { href: '/billing-transparency/', label: 'Billing Transparency' },
  { href: '/small-prepaid-test/', label: 'Small Prepaid Test' },
];

const benchmarkData = [
  { category: 'LLM', provider: 'Anthropic', model: 'Claude 3.5 Sonnet 4', unit: 'per 1M tokens', input: '$3.00', output: '$15.00', notes: '' },
  { category: 'LLM', provider: 'Anthropic', model: 'Claude 3.5 Sonnet 4 (cached)', unit: 'per 1M tokens', input: '$0.30', output: '—', notes: 'Cache read' },
  { category: 'LLM', provider: 'Anthropic', model: 'Claude Sonnet 4', unit: 'per 1M tokens', input: '$1.50', output: '$6.00', notes: '' },
  { category: 'LLM', provider: 'Anthropic', model: 'Claude Sonnet 4 (cached)', unit: 'per 1M tokens', input: '$0.15', output: '—', notes: 'Cache read' },
  { category: 'LLM', provider: 'Anthropic', model: 'Claude Opus 4', unit: 'per 1M tokens', input: '$15.00', output: '$75.00', notes: '' },
  { category: 'LLM', provider: 'OpenAI', model: 'gpt-4o', unit: 'per 1M tokens', input: '$2.50', output: '$10.00', notes: '' },
  { category: 'LLM', provider: 'OpenAI', model: 'gpt-4o-mini', unit: 'per 1M tokens', input: '$0.15', output: '$0.60', notes: '' },
  { category: 'LLM', provider: 'OpenAI', model: 'o3', unit: 'per 1M tokens', input: '$15.00', output: '$60.00', notes: 'Reasoning model' },
  { category: 'LLM', provider: 'OpenAI', model: 'o4-mini', unit: 'per 1M tokens', input: '$1.10', output: '$14.00', notes: 'Compact reasoning' },
  { category: 'LLM', provider: 'OpenAI', model: 'gpt-4.1', unit: 'per 1M tokens', input: '$2.00', output: '$8.00', notes: '' },
  { category: 'LLM', provider: 'Google', model: 'gemini-2.5-flash', unit: 'per 1M tokens', input: '$0.30', output: '$1.20', notes: '' },
  { category: 'LLM', provider: 'Google', model: 'gemini-2.0-flash', unit: 'per 1M tokens', input: '$0.10', output: '$0.40', notes: '' },
  { category: 'Image', provider: 'OpenAI', model: 'gpt-image-2', unit: 'per image', input: '—', output: '—', notes: 'Price varies by quality, size, count' },
  { category: 'Image', provider: 'Runway', model: 'gen4_image (720p)', unit: 'per image', input: '—', output: '$0.05', notes: '5 credits at $0.01/credit' },
  { category: 'Image', provider: 'Runway', model: 'gen4_image_turbo', unit: 'per image', input: '—', output: '$0.02', notes: '2 credits at $0.01/credit' },
  { category: 'Video', provider: 'Runway', model: 'gen4.5', unit: 'per second', input: '—', output: '$0.12', notes: '12 credits/sec at $0.01/credit' },
  { category: 'Video', provider: 'Runway', model: 'gen4_turbo', unit: 'per second', input: '—', output: '$0.05', notes: '5 credits/sec' },
  { category: 'Video', provider: 'Runway', model: 'seedance2_fast (480p/720p)', unit: 'per second', input: '—', output: '$0.29', notes: '29 credits/sec' },
  { category: 'Video', provider: 'Runway', model: 'aleph2', unit: 'per second', input: '—', output: '$0.28', notes: '28 credits/sec; 56-credit minimum' },
  { category: 'Video', provider: 'OpenAI', model: 'sora-2 (720p)', unit: 'per second', input: '—', output: '$0.10', notes: 'DEPRECATED — shutdown 2026-09-24' },
  { category: 'Video', provider: 'OpenAI', model: 'sora-2-pro (720p)', unit: 'per second', input: '—', output: '$0.30', notes: 'DEPRECATED — shutdown 2026-09-24' },
  { category: 'Video', provider: 'OpenAI', model: 'sora-2-pro (1080p)', unit: 'per second', input: '—', output: '$0.70', notes: 'DEPRECATED — shutdown 2026-09-24' },
  { category: 'Video', provider: 'OpenAI', model: 'sora-2 (720p batch)', unit: 'per second', input: '—', output: '$0.05', notes: 'DEPRECATED — shutdown 2026-09-24' },
  { category: 'LLM', provider: 'OpenRouter', model: 'Various', unit: 'per 1M tokens', input: 'varies', output: 'varies', notes: 'Prices vary by model and provider. Check openrouter.ai/docs/models' },
];
---

<PageLayout
  title="2026 AI API Cost Benchmark: Estimates"
  description="Estimate real AI API costs across LLM, coding-agent, image and video workloads. Model tokens, retries, caching and failed jobs, then export the benchmark as CSV."
  canonical={`${siteUrl}${route}`}
  type="article"
  lastUpdated={currentDate}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org", "@type": "Article",
      "headline": "2026 AI API Cost Benchmark: LLM, Image and Video Costs",
      "description": "Estimate real AI API costs across LLM, coding-agent, image and video workloads. Model tokens, retries, caching and failed jobs, then export the benchmark as CSV.",
      "author": { "@type": "Organization", "name": "AICostPlanner" },
      "publisher": { "@type": "Organization", "name": "AICostPlanner", "url": siteUrl },
      "datePublished": currentDate, "dateModified": currentDate,
      "mainEntityOfPage": { "@type": "WebPage", "@id": `${siteUrl}${route}` }
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org", "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
        { "@type": "ListItem", "position": 2, "name": "AI API Cost Benchmark", "item": `${siteUrl}${route}` }
      ]
    })} />
  </Fragment>

  <Header />
  <main>
    <section class="hero-dark">
      <div class="container">
        <Breadcrumb items={breadcrumbs} />
        <h1 class="page-title">2026 AI API Cost Benchmark</h1>
        <p class="page-meta"><span class="label-mono">Last reviewed: {lastReviewed}</span></p>
      </div>
    </section>

    <section class="section-light content-section">
      <div class="container container-narrow">

        <div class="quick-answer">
          <h2>Quick Answer</h2>
          <p>
            Listed API prices are only a starting point. Real monthly budgets also depend on input-to-output
            token ratios, repeated conversation context, coding-agent tool results, cache behavior, retry
            rates, failed or moderated media jobs and user regeneration choices. This calculator separates
            the official per-unit rate from an operational planning budget that accounts for those multipliers.
          </p>
        </div>

        <!-- HERO CTA STRIP -->
        <div class="benchmark-hero-strip">
          <p class="benchmark-subtitle">Estimate LLM, coding-agent, image and video API costs before you ship.</p>
          <div class="benchmark-hero-actions">
            <a href="#calculator" class="btn btn-primary-dark">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16v2H4zM4 10h16v2H4zM4 16h16v2H4zM10 4v16M7 7h6M7 13h6"/></svg>
              Calculate your cost
            </a>
            <a href="/data/ai-api-cost-benchmark-2026-06.csv" class="btn btn-secondary-dark" download>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
              Download CSV
            </a>
          </div>
          <p class="benchmark-source-note">
            Prices sourced from official provider pricing pages as of {lastReviewed}.
            All figures are pricing snapshots — verify before production use.
          </p>
        </div>

        <!-- TABLE OF CONTENTS -->
        <nav class="toc" aria-label="Table of contents">
          <h2>Contents</h2>
          <ol>
            <li><a href="#calculator">Quick Estimate Calculator</a></li>
            <li><a href="#llm-cost">LLM API Cost</a></li>
            <li><a href="#agent-cost">Coding-Agent Cost</a></li>
            <li><a href="#image-cost">Image Generation Cost</a></li>
            <li><a href="#video-cost">Video Generation Cost</a></li>
            <li><a href="#hidden-costs">Hidden Cost Multipliers</a></li>
            <li><a href="#methodology">Benchmark Methodology</a></li>
            <li><a href="#benchmark-table">Benchmark Data</a></li>
            <li><a href="#download">Download CSV</a></li>
            <li><a href="#sources">Official Sources</a></li>
            <li><a href="#faq">FAQ</a></li>
          </ol>
        </nav>

        <!-- CALCULATOR -->
        <div id="calculator" class="calculator-wrapper">
          <h2>Quick Estimate Calculator</h2>
          <p class="calc-intro">
            These are editable planning scenarios, not universal usage averages.
            Fill in your own numbers or load one of the presets below.
          </p>

          <!-- PRESETS -->
          <div class="presets-bar">
            <span class="presets-label">Presets:</span>
            <button class="preset-btn" data-preset="prototype" type="button">Prototype</button>
            <button class="preset-btn" data-preset="small-production" type="button">Small Production App</button>
            <button class="preset-btn" data-preset="agent-heavy" type="button">Agent-Heavy Workflow</button>
            <button class="preset-btn" data-preset="reset" type="button">Reset</button>
          </div>

          <!-- TABS -->
          <div class="calc-tabs" role="tablist">
            <button class="calc-tab active" role="tab" data-tab="llm" aria-selected="true" type="button">LLM App</button>
            <button class="calc-tab" role="tab" data-tab="agent" aria-selected="false" type="button">Coding Agent</button>
            <button class="calc-tab" role="tab" data-tab="image" aria-selected="false" type="button">Image Generation</button>
            <button class="calc-tab" role="tab" data-tab="video" aria-selected="false" type="button">Video Generation</button>
          </div>

          <!-- LLM CALCULATOR -->
          <div id="calc-llm" class="calc-panel active" role="tabpanel" aria-labelledby="tab-llm">
            <div class="calc-inputs">
              <div class="calc-row">
                <div class="calc-field">
                  <label for="llm-users">Monthly active users</label>
                  <input type="number" id="llm-users" min="1" max="10000000" step="1" value="100" aria-describedby="llm-users-help" />
                  <span class="field-help" id="llm-users-help">Number of users who make at least one API request per month.</span>
                </div>
                <div class="calc-field">
                  <label for="llm-days">Active days per month</label>
                  <input type="number" id="llm-days" min="1" max="31" step="1" value="20" aria-describedby="llm-days-help" />
                  <span class="field-help" id="llm-days-help">Average days each active user makes a request.</span>
                </div>
              </div>
              <div class="calc-row">
                <div class="calc-field">
                  <label for="llm-rpu">Requests per active user per day</label>
                  <input type="number" id="llm-rpu" min="0.1" max="1000" step="0.1" value="3" aria-describedby="llm-rpu-help" />
                  <span class="field-help" id="llm-rpu-help">Average API requests per active user per active day.</span>
                </div>
                <div class="calc-field">
                  <label for="llm-itok">Average input tokens per request</label>
                  <input type="number" id="llm-itok" min="1" max="1000000" step="1" value="2000" aria-describedby="llm-itok-help" />
                  <span class="field-help" id="llm-itok-help">Prompt tokens, including conversation context.</span>
                </div>
              </div>
              <div class="calc-row">
                <div class="calc-field">
                  <label for="llm-otok">Average output tokens per request</label>
                  <input type="number" id="llm-otok" min="1" max="1000000" step="1" value="500" aria-describedby="llm-otok-help" />
                  <span class="field-help" id="llm-otok-help">Completion tokens per response.</span>
                </div>
                <div class="calc-field">
                  <label for="llm-ipr">Input price per 1M tokens (USD)</label>
                  <input type="number" id="llm-ipr" min="0" max="10000" step="0.01" value="3.00" aria-describedby="llm-ipr-help" />
                  <span class="field-help" id="llm-ipr-help">Check the provider pricing page for current rate.</span>
                </div>
              </div>
              <div class="calc-row">
                <div class="calc-field">
                  <label for="llm-opr">Output price per 1M tokens (USD)</label>
                  <input type="number" id="llm-opr" min="0" max="10000" step="0.01" value="15.00" aria-describedby="llm-opr-help" />
                  <span class="field-help" id="llm-opr-help">Check the provider pricing page for current rate.</span>
                </div>
                <div class="calc-field">
                  <label for="llm-retry">Retry rate (%)</label>
                  <input type="number" id="llm-retry" min="0" max="100" step="0.1" value="3" aria-describedby="llm-retry-help" />
                  <span class="field-help" id="llm-retry-help">Estimated percentage of requests that are retried.</span>
                </div>
              </div>
              <div class="calc-row">
                <div class="calc-field calc-field--full">
                  <label for="llm-buf">Budget buffer (%)</label>
                  <input type="number" id="llm-buf" min="0" max="500" step="1" value="15" aria-describedby="llm-buf-help" />
                  <span class="field-help" id="llm-buf-help">Extra percentage added to cover retries, context growth and unexpected load.</span>
                </div>
              </div>
            </div>
            <div class="calc-result" id="llm-result" aria-live="polite">
              <div class="result-empty">Enter values above to see your estimated monthly cost.</div>
            </div>
          </div>

          <!-- AGENT CALCULATOR -->
          <div id="calc-agent" class="calc-panel" role="tabpanel" aria-labelledby="tab-agent" hidden>
            <div class="calc-inputs">
              <div class="calc-row">
                <div class="calc-field">
                  <label for="agent-tasks">Tasks per month</label>
                  <input type="number" id="agent-tasks" min="1" max="1000000" step="1" value="500" aria-describedby="agent-tasks-help" />
                  <span class="field-help" id="agent-tasks-help">Completed coding tasks per month.</span>
                </div>
                <div class="calc-field">
                  <label for="agent-calls">Model calls per completed task</label>
                  <input type="number" id="agent-calls" min="1" max="1000" step="1" value="8" aria-describedby="agent-calls-help" />
                  <span class="field-help" id="agent-calls-help">Each task may require multiple model calls to complete.</span>
                </div>
              </div>
              <div class="calc-row">
                <div class="calc-field">
                  <label for="agent-itok">Average input tokens per call</label>
                  <input type="number" id="agent-itok" min="1" max="1000000" step="1" value="20000" aria-describedby="agent-itok-help" />
                  <span class="field-help" id="agent-itok-help">Prompt tokens per call — typically larger than chat due to context and tools.</span>
                </div>
                <div class="calc-field">
                  <label for="agent-otok">Average output tokens per call</label>
                  <input type="number" id="agent-otok" min="1" max="1000000" step="1" value="3000" aria-describedby="agent-otok-help" />
                  <span class="field-help" id="agent-otok-help">Completion tokens per call.</span>
                </div>
              </div>
              <div class="calc-row">
                <div class="calc-field">
                  <label for="agent-ttok">Tool-result tokens per call</label>
                  <input type="number" id="agent-ttok" min="0" max="1000000" step="1" value="5000" aria-describedby="agent-ttok-help" />
                  <span class="field-help" id="agent-ttok-help">Tool results injected as context in subsequent calls. Varies widely by workflow.</span>
                </div>
                <div class="calc-field">
                  <label for="agent-retry">Retry rate (%)</label>
                  <input type="number" id="agent-retry" min="0" max="100" step="0.1" value="8" aria-describedby="agent-retry-help" />
                  <span class="field-help" id="agent-retry-help">Estimated percentage of calls retried due to error or timeout.</span>
                </div>
              </div>
              <div class="calc-row">
                <div class="calc-field">
                  <label for="agent-ipr">Input price per 1M tokens (USD)</label>
                  <input type="number" id="agent-ipr" min="0" max="10000" step="0.01" value="3.00" />
                </div>
                <div class="calc-field">
                  <label for="agent-opr">Output price per 1M tokens (USD)</label>
                  <input type="number" id="agent-opr" min="0" max="10000" step="0.01" value="15.00" />
                </div>
              </div>
              <div class="calc-row">
                <div class="calc-field">
                  <label for="agent-crdp">Cache read percentage (%)</label>
                  <input type="number" id="agent-crdp" min="0" max="100" step="1" value="30" aria-describedby="agent-crdp-help" />
                  <span class="field-help" id="agent-crdp-help">Approximate percentage of input tokens served from cache (reduces cost).</span>
                </div>
                <div class="calc-field">
                  <label for="agent-crwtp">Cache read discount (%)</label>
                  <input type="number" id="agent-crwtp" min="0" max="100" step="1" value="90" aria-describedby="agent-crwtp-help" />
                  <span class="field-help" id="agent-crwtp-help">Typical cache read discount — Anthropic cache read is 90% off input price.</span>
                </div>
              </div>
              <div class="calc-row">
                <div class="calc-field">
                  <label for="agent-buf">Budget buffer (%)</label>
                  <input type="number" id="agent-buf" min="0" max="500" step="1" value="20" />
                </div>
              </div>
            </div>
            <div class="calc-result" id="agent-result" aria-live="polite">
              <div class="result-empty">Enter values above to see your estimated monthly cost.</div>
            </div>
          </div>

          <!-- IMAGE CALCULATOR -->
          <div id="calc-image" class="calc-panel" role="tabpanel" aria-labelledby="tab-image" hidden>
            <div class="calc-inputs">
              <div class="calc-row">
                <div class="calc-field">
                  <label for="img-permonth">Accepted images per month</label>
                  <input type="number" id="img-permonth" min="1" max="10000000" step="1" value="1000" aria-describedby="img-permonth-help" />
                  <span class="field-help" id="img-permonth-help">Final accepted outputs per month (not submitted jobs).</span>
                </div>
                <div class="calc-field">
                  <label for="img-attempts">Average attempts per accepted image</label>
                  <input type="number" id="img-attempts" min="1" max="100" step="0.1" value="1.5" aria-describedby="img-attempts-help" />
                  <span class="field-help" id="img-attempts-help">Includes rejected or re-generated attempts before acceptance.</span>
                </div>
              </div>
              <div class="calc-row">
                <div class="calc-field">
                  <label for="img-price">Price per generation (USD)</label>
                  <input type="number" id="img-price" min="0" max="100" step="0.001" value="0.04" aria-describedby="img-price-help" />
                  <span class="field-help" id="img-price-help">Per accepted output or per job, depending on provider billing model.</span>
                </div>
                <div class="calc-field">
                  <label for="img-fail">Rejection/failure rate (%)</label>
                  <input type="number" id="img-fail" min="0" max="100" step="0.1" value="10" aria-describedby="img-fail-help" />
                  <span class="field-help" id="img-fail-help">Estimated percentage of submitted jobs that failed or were rejected.</span>
                </div>
              </div>
              <div class="calc-row">
                <div class="calc-field">
                  <label for="img-buf">Budget buffer (%)</label>
                  <input type="number" id="img-buf" min="0" max="500" step="1" value="15" />
                </div>
              </div>
            </div>
            <p class="calc-warning">
              Failed-job billing varies by provider. Verify the provider policy and reconcile the
              request ID with the billing dashboard. Do not assume all failed or retried jobs were billed.
            </p>
            <div class="calc-result" id="image-result" aria-live="polite">
              <div class="result-empty">Enter values above to see your estimated monthly cost.</div>
            </div>
          </div>

          <!-- VIDEO CALCULATOR -->
          <div id="calc-video" class="calc-panel" role="tabpanel" aria-labelledby="tab-video" hidden>
            <div class="calc-inputs">
              <div class="calc-row">
                <div class="calc-field">
                  <label for="vid-videos">Accepted videos per month</label>
                  <input type="number" id="vid-videos" min="1" max="100000" step="1" value="100" aria-describedby="vid-videos-help" />
                  <span class="field-help" id="vid-videos-help">Final accepted video outputs per month.</span>
                </div>
                <div class="calc-field">
                  <label for="vid-attempts">Average attempts per accepted video</label>
                  <input type="number" id="vid-attempts" min="1" max="100" step="0.1" value="1.3" aria-describedby="vid-attempts-help" />
                  <span class="field-help" id="vid-attempts-help">Includes failed, moderated or re-submitted jobs.</span>
                </div>
              </div>
              <div class="calc-row">
                <div class="calc-field">
                  <label for="vid-seconds">Seconds per generated job</label>
                  <input type="number" id="vid-seconds" min="1" max="120" step="1" value="8" aria-describedby="vid-seconds-help" />
                  <span class="field-help" id="vid-seconds-help">Requested duration per job. Maximum varies by provider.</span>
                </div>
                <div class="calc-field">
                  <label for="vid-mode">Billing mode</label>
                  <select id="vid-mode" aria-describedby="vid-mode-help">
                    <option value="per-second">Per second</option>
                    <option value="per-job">Per job (flat)</option>
                  </select>
                  <span class="field-help" id="vid-mode-help">Switch between per-second and per-job pricing.</span>
                </div>
              </div>
              <div class="calc-row">
                <div class="calc-field">
                  <label for="vid-pps">Price per second (USD)</label>
                  <input type="number" id="vid-pps" min="0" max="100" step="0.001" value="0.10" aria-describedby="vid-pps-help" />
                  <span class="field-help" id="vid-pps-help">Rate per generated second. Check the video provider pricing page.</span>
                </div>
                <div class="calc-field">
                  <label for="vid-ppj">Price per job (USD)</label>
                  <input type="number" id="vid-ppj" min="0" max="100" step="0.01" value="0.80" aria-describedby="vid-ppj-help" />
                  <span class="field-help" id="vid-ppj-help">Flat cost per completed job (e.g. 8s × $0.10/s = $0.80).</span>
                </div>
              </div>
              <div class="calc-row">
                <div class="calc-field">
                  <label for="vid-fail">Failure/retry rate (%)</label>
                  <input type="number" id="vid-fail" min="0" max="100" step="0.1" value="20" aria-describedby="vid-fail-help" />
                  <span class="field-help" id="vid-fail-help">Estimated percentage of submitted jobs that failed or were retried.</span>
                </div>
                <div class="calc-field">
                  <label for="vid-buf">Budget buffer (%)</label>
                  <input type="number" id="vid-buf" min="0" max="500" step="1" value="20" />
                </div>
              </div>
            </div>
            <p class="calc-warning">
              Failed-job billing varies by provider. Verify the provider policy and reconcile the
              job ID with the billing dashboard. Do not assume all failed or retried jobs were billed.
            </p>
            <div class="calc-result" id="video-result" aria-live="polite">
              <div class="result-empty">Enter values above to see your estimated monthly cost.</div>
            </div>
          </div>

          <!-- COPY / EXPORT -->
          <div class="calc-actions">
            <button class="btn btn-secondary-dark" id="calc-copy" type="button">Copy result</button>
            <button class="btn btn-secondary-dark" id="calc-export" type="button">Export CSV row</button>
          </div>
        </div>

        <!-- WHY LISTED PRICE IS NOT FINAL -->
        <h2 id="llm-cost">Why Listed API Price Is Not the Final Product Cost</h2>
        <p>
          A provider's per-token, per-image or per-second price is the base unit, but real product
          costs diverge from it through several compounding factors:
        </p>
        <ul>
          <li><strong>Input-to-output ratio</strong> — Prompt-heavy applications with short responses cost more per useful output than balanced request-response flows.</li>
          <li><strong>Repeated conversation context</strong> — Multi-turn conversations re-send prior turns as context. The same 10-turn conversation can cost 5–10&times; a single-turn exchange.</li>
          <li><strong>Coding-agent tool results</strong> — Each tool call returns data that is injected into the next model call as context. A single coding task can accumulate thousands of tool-result tokens.</li>
          <li><strong>Cache write and read</strong> — Some providers charge for tokens stored as cache and credit cache reads at a significant discount. Using cache effectively can reduce input costs by 50–90%.</li>
          <li><strong>Retries</strong> — Each retry doubles the cost of the original operation. Unhandled errors, timeouts and rate-limit backoff can multiply spend unexpectedly.</li>
          <li><strong>Duplicate or overlapped jobs</strong> — A client timeout followed by a new submission creates two billed jobs instead of one.</li>
          <li><strong>Failed or moderated media tasks</strong> — Some providers bill job creation regardless of outcome. Moderation blocks, invalid inputs and queue timeouts all create billable events.</li>
          <li><strong>User rejection and regeneration</strong> — If users reject outputs and regenerate, each attempt is a new API call. Image and video workflows are particularly sensitive to this.</li>
          <li><strong>Gateway and marketplace routing</strong> — OpenRouter and similar marketplaces add routing overhead and may charge differently from direct provider APIs.</li>
          <li><strong>Billing reconciliation lag</strong> — Dashboard usage may not reflect billed amounts until hours after the request, making real-time cost monitoring difficult.</li>
        </ul>
        <p>
          This calculator separates the official unit rate from a planning budget that multiplies
          the base cost by retry rate and a buffer. Always cross-reference with your actual
          organization usage data before committing a budget.
        </p>

        <!-- LLM COST SECTION -->
        <h2 id="agent-cost">LLM API Cost</h2>
        <p>
          LLM API cost is driven by tokens. Every request sends input tokens (prompt + conversation
          context) and receives output tokens (completion). Prices are quoted per million tokens (M tokens).
        </p>
        <pre><code>monthly_requests =
  monthly_active_users
  × active_days_per_month
  × requests_per_user_per_day

input_cost =
  monthly_requests
  × average_input_tokens
  ÷ 1,000,000
  × input_price_per_million

output_cost =
  monthly_requests
  × average_output_tokens
  ÷ 1,000,000
  × output_price_per_million

base_cost = input_cost + output_cost

retry_adjusted_cost =
  base_cost × (1 + retry_rate_as_decimal)

planned_budget =
  retry_adjusted_cost × (1 + buffer_as_decimal)</code></pre>

        <!-- CODING AGENT SECTION -->
        <h2 id="image-cost">Coding-Agent Cost</h2>
        <p>
          Coding agents cost more than simple chat requests because each completed task involves
          multiple model calls, large context windows and tool-result token accumulation.
        </p>
        <p>
          Tool calls themselves are not free operations — they generate output tokens and inject
          result data into subsequent calls, increasing the input token count of every following
          request. Specific costs depend on the model, tool definitions, context window size,
          cache usage and provider billing rules. Use your actual usage records to calibrate
          these estimates.
        </p>
        <pre><code>monthly_model_calls =
  tasks_per_month
  × calls_per_task

total_input_tokens_per_call =
  prompt_tokens + tool_result_tokens

base_call_cost =
  (prompt_tokens + tool_result_tokens) ÷ 1,000,000 × input_price
  + output_tokens ÷ 1,000,000 × output_price

monthly_base_cost =
  monthly_model_calls × base_call_cost

effective_input_cost =
  (1 - cache_read_pct) × full_price
  + cache_read_pct × cache_discount_price

planned_budget =
  monthly_base_cost × (1 + retry_rate) × (1 + buffer)</code></pre>

        <!-- IMAGE GENERATION SECTION -->
        <h2 id="video-cost">Image Generation Cost</h2>
        <p>
          Image generation is usually billed per accepted output or per submitted job. The effective
          cost per accepted image is higher than the listed per-generation price because rejected
          or re-generated attempts also consume budget.
        </p>
        <pre><code>submitted_jobs =
  accepted_images × average_attempts_per_accepted

effective_cost_per_accepted =
  listed_price × average_attempts_per_accepted

monthly_generation_cost =
  submitted_jobs × listed_price

effective_output_cost =
  monthly_generation_cost ÷ accepted_images

planned_budget =
  submitted_jobs × listed_price × (1 + buffer)</code></pre>
        <p>
          Do not assume all failed or retried image generation jobs are billed or free.
          Inspect the provider's failure policy and check the billing dashboard before
          assuming a uniform treatment.
        </p>

        <!-- VIDEO GENERATION SECTION -->
        <h2 id="hidden-costs">Video Generation Cost</h2>
        <p>
          Video generation is typically billed by generated duration (seconds) or per job.
          Async job lifecycle — creation, polling, completion, failure and webhook delivery —
          means that timeouts, retries and moderation blocks can all create billable events.
        </p>
        <pre><code>submitted_jobs =
  accepted_videos × attempts_per_accepted

total_generated_seconds =
  submitted_jobs × seconds_per_job

base_spend =
  (billing_mode == per-second)
    ? total_generated_seconds × price_per_second
    : submitted_jobs × price_per_job

planned_budget =
  base_spend × (1 + buffer)</code></pre>

